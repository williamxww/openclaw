{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug src/agents",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${env:HOME}/.nvm/versions/node/v24.11.0/bin/node",
      "runtimeArgs": ["--import", "tsx"],
      "program": "${workspaceFolder}/src/entry.ts",
      "args": ["--dev", "gateway", "run"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "NODE_DISABLE_COMPILE_CACHE": "1",
        "PATH": "${env:HOME}/.nvm/versions/node/v24.11.0/bin:${env:PATH}"
      },
      "sourceMaps": true,
      "smartStep": true,
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**"
      ]
    }
  ]
}
